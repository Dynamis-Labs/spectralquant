{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://niashwin.github.io/spectralquant-v2/schemas/evidence_catalog.schema.json",
  "title": "SpectralQuant v2 Evidence Catalog",
  "description": "Schema for docs/evidence_catalog.json. Locks the structural invariants the v2 report depends on.",
  "type": "object",
  "required": [
    "schema_version",
    "repo",
    "entries",
    "gaps"
  ],
  "additionalProperties": true,
  "properties": {
    "schema_version": {
      "type": "string",
      "enum": [
        "1"
      ]
    },
    "repo": {
      "type": "string",
      "minLength": 1
    },
    "baseline_repo": {
      "type": "string"
    },
    "generated_at": {
      "type": "string"
    },
    "generated_by": {
      "type": "string"
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/entry"
      }
    },
    "gaps": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/gap"
      }
    }
  },
  "$defs": {
    "entry": {
      "type": "object",
      "required": [
        "id",
        "kind",
        "path",
        "supports",
        "caveats"
      ],
      "additionalProperties": true,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^(V1-(PAPER|README|IMPL|EXP|RESULT|FIG|CONF|TEST)-[0-9]{3}[a-z]?|V2-SPEC-[0-9]{3}|RUN-THREEWAY-(MISTRAL|QWEN)-[0-9]+BIT|RUN-THREEWAY-[A-Z0-9-]+|RUN-ACCOUNTING-[A-Z0-9-]+|RUN-WATERFILL-[A-Z0-9-]+|RUN-PERPLEXITY-[A-Z0-9.\\-]+|RUN-LATENCY-[A-Z0-9.\\-]+|RUN-GENERATION-[A-Z0-9.\\-]+|RUN-LONGBENCH-[A-Z0-9.\\-]+)$"
        },
        "kind": {
          "type": "string",
          "enum": [
            "paper_source",
            "paper_compiled",
            "paper_bib",
            "paper_figures_dir",
            "figure_generator",
            "readme_claims_table",
            "code_module",
            "experiment_script",
            "result_json",
            "figure",
            "config",
            "build",
            "test",
            "spec",
            "modal_run_artifact",
            "modal_run_artifact_partial"
          ]
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "supports": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "caveats": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "produces": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "produced_by": {
          "type": "string"
        },
        "extracted": {
          "type": "object"
        },
        "files": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "gap": {
      "type": "object",
      "required": [
        "id",
        "summary",
        "blocks_v2_claims",
        "resolution_options"
      ],
      "additionalProperties": true,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^V1-GAP-[0-9]{3}[a-z]?$"
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "blocks_v2_claims": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "resolution_options": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}