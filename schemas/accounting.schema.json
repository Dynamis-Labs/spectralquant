{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://niashwin.github.io/spectralquant-v2/schemas/accounting.schema.json",
  "title": "SpectralQuant v2 Compression Accounting",
  "description": "Schema for the per-method compression_accounting object (spec section 10) and standalone accounting-audit JSONs.",
  "type": "object",
  "required": [
    "method",
    "avg_bits_arg",
    "head_dim",
    "d_eff",
    "k_mse_bits",
    "k_qjl_bits",
    "k_norm_bits",
    "v_mse_bits",
    "v_norm_bits",
    "total_k_bits",
    "total_v_bits",
    "average_slot_bits",
    "fp16_slot_bits",
    "compression_ratio",
    "formula_version"
  ],
  "additionalProperties": true,
  "properties": {
    "method": {
      "type": "string",
      "enum": ["turboquant", "spectralquant_v1", "spectralquant_v2"]
    },
    "avg_bits_arg": {
      "type": "integer",
      "minimum": 1,
      "maximum": 16
    },
    "head_dim": {
      "type": "integer",
      "minimum": 1
    },
    "d_eff": {
      "anyOf": [
        { "type": "integer", "minimum": 0 },
        { "type": "null" }
      ]
    },
    "k_mse_bits":  { "type": "number", "minimum": 0 },
    "k_qjl_bits":  { "type": "number", "minimum": 0 },
    "k_norm_bits": { "type": "number", "minimum": 0 },
    "v_mse_bits":  { "type": "number", "minimum": 0 },
    "v_norm_bits": { "type": "number", "minimum": 0 },
    "total_k_bits":     { "type": "number", "minimum": 0 },
    "total_v_bits":     { "type": "number", "minimum": 0 },
    "average_slot_bits": { "type": "number", "exclusiveMinimum": 0 },
    "fp16_slot_bits":    { "type": "number", "exclusiveMinimum": 0 },
    "compression_ratio": { "type": "number", "exclusiveMinimum": 0 },
    "formula_version":   { "type": "string", "minLength": 1 },
    "waterfill_allocation": {
      "type": "array",
      "items": { "type": "integer", "minimum": 0 }
    }
  }
}
