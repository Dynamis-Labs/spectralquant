{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://niashwin.github.io/spectralquant-v2/schemas/three_way_result.schema.json",
  "title": "SpectralQuant v2 Three-Way Benchmark Result",
  "description": "Schema for JSON files produced by experiments/run_three_way.py (spec section 13). Each file holds one (model, bits, seed) triplet and three method records.",
  "type": "object",
  "required": [
    "run_id",
    "timestamp",
    "repo",
    "commit",
    "command",
    "model",
    "hardware",
    "software",
    "data",
    "calibration",
    "methods",
    "evidence_ids"
  ],
  "additionalProperties": true,
  "properties": {
    "run_id":    { "type": "string", "minLength": 1 },
    "timestamp": { "type": "string", "minLength": 1 },
    "repo":      { "type": "string", "minLength": 1 },
    "commit":    { "type": "string", "minLength": 7 },
    "command":   { "type": "string", "minLength": 1 },

    "model": {
      "type": "object",
      "required": ["name", "layers", "q_heads", "kv_heads", "head_dim", "gqa_ratio"],
      "additionalProperties": true,
      "properties": {
        "name":      { "type": "string", "minLength": 1 },
        "layers":    { "type": "integer", "minimum": 1 },
        "q_heads":   { "type": "integer", "minimum": 1 },
        "kv_heads":  { "type": "integer", "minimum": 1 },
        "head_dim":  { "type": "integer", "minimum": 1 },
        "gqa_ratio": { "type": "integer", "minimum": 1 }
      }
    },

    "hardware": {
      "type": "object",
      "required": ["gpu", "cuda"],
      "additionalProperties": true,
      "properties": {
        "gpu":  { "type": "string" },
        "cuda": { "type": "string" }
      }
    },

    "software": {
      "type": "object",
      "required": ["python", "torch", "transformers", "datasets"],
      "additionalProperties": true,
      "properties": {
        "python":       { "type": "string" },
        "torch":        { "type": "string" },
        "transformers": { "type": "string" },
        "datasets":     { "type": "string" }
      }
    },

    "data": {
      "type": "object",
      "required": [
        "calibration_corpus",
        "n_calib",
        "eval_corpus",
        "n_eval",
        "max_calib_tokens",
        "disjoint_eval"
      ],
      "additionalProperties": true,
      "properties": {
        "calibration_corpus": { "type": "string", "minLength": 1 },
        "n_calib":            { "type": "integer", "minimum": 1 },
        "eval_corpus":        { "type": "string", "minLength": 1 },
        "n_eval":             { "type": "integer", "minimum": 1 },
        "max_calib_tokens":   { "type": "integer", "minimum": 1 },
        "disjoint_eval":      { "type": "boolean" }
      }
    },

    "calibration": {
      "type": "object",
      "required": [
        "normalize_keys",
        "key_space",
        "d_eff_method",
        "d_eff_rounding",
        "d_eff_min",
        "d_eff_max"
      ],
      "additionalProperties": true,
      "properties": {
        "normalize_keys": { "type": "boolean" },
        "key_space":      { "type": "string", "enum": ["pre_rope", "post_rope"] },
        "d_eff_method":   { "type": "string", "minLength": 1 },
        "d_eff_rounding": { "type": "string", "enum": ["ceil", "floor", "round", "nearest"] },
        "d_eff_min":      { "type": "integer", "minimum": 0 },
        "d_eff_max":      { "type": "integer", "minimum": 1 },
        "d_eff_stats": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "mean": { "type": "number" },
            "min":  { "type": "number" },
            "max":  { "type": "number" }
          }
        }
      }
    },

    "methods": {
      "type": "object",
      "required": ["turboquant", "spectralquant_v1", "spectralquant_v2"],
      "additionalProperties": false,
      "properties": {
        "turboquant":       { "$ref": "#/$defs/method_record" },
        "spectralquant_v1": { "$ref": "#/$defs/method_record" },
        "spectralquant_v2": { "$ref": "#/$defs/method_record" }
      }
    },

    "evidence_ids": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    }
  },

  "$defs": {
    "method_record": {
      "type": "object",
      "required": ["attn_cosine_mean", "compression_accounting", "per_layer", "evidence_ids"],
      "additionalProperties": true,
      "properties": {
        "attn_cosine_mean": { "type": "number", "minimum": -1, "maximum": 1 },
        "attn_cosine_std":  { "type": "number", "minimum": 0 },
        "compression_accounting": {
          "$ref": "https://niashwin.github.io/spectralquant-v2/schemas/accounting.schema.json"
        },
        "per_layer": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["layer_index", "d_eff", "attn_cosine_mean"],
            "additionalProperties": true,
            "properties": {
              "layer_index":      { "type": "integer", "minimum": 0 },
              "d_eff":            { "type": "integer", "minimum": 0 },
              "attn_cosine_mean": { "type": "number", "minimum": -1, "maximum": 1 },
              "attn_cosine_min":  { "type": "number", "minimum": -1, "maximum": 1 },
              "attn_cosine_max":  { "type": "number", "minimum": -1, "maximum": 1 }
            }
          }
        },
        "evidence_ids": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
