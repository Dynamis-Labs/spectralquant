# SpectralQuant v2 — example environment variables
#
# Copy this file to `.env` and fill in real values locally. The real `.env`
# is ignored by git (.gitignore). NEVER commit a populated `.env`.
#
# Real token values must NEVER appear in any committed file.

# Hugging Face access token. The account behind this token must have
# accepted the license for `mistralai/Mistral-7B-v0.3`.
HF_TOKEN=
# Equivalent name some HF tools read; set to the same value as HF_TOKEN if needed.
HUGGING_FACE_HUB_TOKEN=

# Modal CLI tokens. Prefer `~/.modal.toml` (created by `modal token new`)
# over env vars; these are listed for completeness only.
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=

# Optional: Weights & Biases logging.
# WANDB_API_KEY=
